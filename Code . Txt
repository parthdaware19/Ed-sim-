END


✅ 14. LED Interfacing
ORG 0000H

LOOP: MOV P1, #0FFH
ACALL DELAY
MOV P1, #00H
ACALL DELAY
SJMP LOOP

DELAY: MOV R0, #255
D1: DJNZ R0, D1
RET
END


✅ 15. Seven Segment (0–9)
ORG 0000H
MOV DPTR, #TABLE
MOV R0, #00H

LOOP: MOV A, R0
MOVC A, @A+DPTR
MOV P1, A
ACALL DELAY
INC R0
CJNE R0, #0AH, LOOP
MOV R0, #00H
SJMP LOOP

TABLE: DB 3FH,06H,5BH,4FH,66H,6DH,7DH,07H,7FH,6FH

DELAY: MOV R1, #255
D1: DJNZ R1, D1
RET
END


