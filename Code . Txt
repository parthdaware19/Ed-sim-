✅ 9. Stepper (LED Rotation)
ORG 0000H
MOV A, #01H

LOOP: MOV P1, A
ACALL DELAY
RL A
CJNE A, #10H, LOOP
MOV A, #01H
SJMP LOOP

DELAY: MOV R0, #255
D1: DJNZ R0, D1
RET
END


✅ 10. Sensor (Switch → LED)
ORG 0000H

LOOP: MOV A, P1
MOV P2, A
SJMP LOOP

END


✅ 11. PIR Sensor
ORG 0000H

LOOP: JB P1.0, ON
CLR P2.0
SJMP LOOP

ON: SETB P2.0
SJMP LOOP

END

✅ 12. Ultrasonic
ORG 0000H

LOOP: JB P1.1, DETECT
CLR P2.0
SJMP LOOP

DETECT: SETB P2.0
SJMP LOOP

END


