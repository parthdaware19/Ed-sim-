✅ 9. Stepper (LED Rotation)
ORG 0000H
MOV A, #01H

LOOP: MOV P1, A
ACALL DELAY
RL A
CJNE A, #10H, LOOP
MOV A, #01H
SJMP LOOP

DELAY: MOV R0, #255
D1: DJNZ R0, D1
RET
END


✅ 10. Sensor (Switch → LED)
ORG 0000H

LOOP: MOV A, P1
