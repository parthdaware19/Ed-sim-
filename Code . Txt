END

✅ 5. Timer Delay
ORG 0000H
MOV TMOD, #01H

LOOP: MOV TH0, #0FCH
MOV TL0, #66H
SETB TR0

WAIT: JNB TF0, WAIT
CLR TR0
CLR TF0
CPL P1.0
SJMP LOOP

END


✅ 6. Interrupt (Manual Trigger INT0)
ORG 0000H
SJMP MAIN

ORG 0003H
CPL P1.0
RETI

MAIN: SETB EA
SETB EX0
SETB IT0

HERE: SJMP HERE
END

