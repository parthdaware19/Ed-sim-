✅ 1. LED Blink
ORG 0000H
START: MOV P1, #00H
LOOP: CPL P1.0
ACALL DELAY
SJMP LOOP

DELAY: MOV R2, #200
D1: MOV R1, #255
D2: DJNZ R1, D2
DJNZ R2, D1
RET
END

✅ 2. Addition
ORG 0000H
MOV A, #25H
MOV B, #15H
ADD A, B
MOV P1, A
END

✅ 3. Block Transfer
ORG 0000H
MOV R0, #30H
MOV R1, #40H
MOV R2, #05H

LOOP: MOV A, @R0
MOV @R1, A
INC R0
INC R1
DJNZ R2, LOOP

HERE: SJMP HERE
END

✅ 4. Logic Operations
ORG 0000H
